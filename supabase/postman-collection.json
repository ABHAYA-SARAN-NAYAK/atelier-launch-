{
  "info": {
    "name": "Atelier Launch API",
    "description": "Complete API collection for the Atelier Launch fashion marketplace",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-project-id.supabase.co/functions/v1",
      "type": "string"
    },
    {
      "key": "anon_key",
      "value": "your-anon-key",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup - Buyer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testbuyer@example.com\",\n  \"password\": \"SecurePass1\",\n  \"full_name\": \"Test Buyer\",\n  \"user_type\": \"buyer\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth-signup", "host": ["{{base_url}}"], "path": ["auth-signup"] }
          }
        },
        {
          "name": "Signup - Designer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testdesigner@example.com\",\n  \"password\": \"SecurePass1\",\n  \"full_name\": \"Test Designer\",\n  \"user_type\": \"student\",\n  \"school_name\": \"Parsons School of Design\",\n  \"graduation_year\": 2025,\n  \"specialization\": \"womenswear\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth-signup", "host": ["{{base_url}}"], "path": ["auth-signup"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.session) {",
                  "    pm.collectionVariables.set('access_token', jsonData.session.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testdesigner@example.com\",\n  \"password\": \"SecurePass1\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth-login", "host": ["{{base_url}}"], "path": ["auth-login"] }
          }
        }
      ]
    },
    {
      "name": "Collections",
      "item": [
        {
          "name": "List Collections",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": {
              "raw": "{{base_url}}/collections?status=live&sort=recent&limit=20",
              "host": ["{{base_url}}"],
              "path": ["collections"],
              "query": [
                { "key": "status", "value": "live" },
                { "key": "sort", "value": "recent" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Collection by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/collections/{{collection_id}}", "host": ["{{base_url}}"], "path": ["collections", "{{collection_id}}"] }
          }
        },
        {
          "name": "Create Collection",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Collection\",\n  \"description\": \"A test collection drop\",\n  \"drop_start_date\": \"2025-02-01T18:00:00Z\",\n  \"drop_end_date\": \"2025-02-04T18:00:00Z\"\n}"
            },
            "url": { "raw": "{{base_url}}/collections", "host": ["{{base_url}}"], "path": ["collections"] }
          }
        },
        {
          "name": "Update Collection",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Collection Title\"\n}"
            },
            "url": { "raw": "{{base_url}}/collections/{{collection_id}}", "host": ["{{base_url}}"], "path": ["collections", "{{collection_id}}"] }
          }
        },
        {
          "name": "Delete Collection",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/collections/{{collection_id}}", "host": ["{{base_url}}"], "path": ["collections", "{{collection_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collection_id\": \"{{collection_id}}\",\n  \"name\": \"Test Product\",\n  \"description\": \"A beautiful test product\",\n  \"price\": 150.00,\n  \"quantity_available\": 10,\n  \"sizes_available\": [\"S\", \"M\", \"L\"],\n  \"primary_image_url\": \"https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=600\",\n  \"materials_used\": \"100% Cotton\",\n  \"care_instructions\": \"Machine wash cold\"\n}"
            },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product Name\",\n  \"price\": 175.00\n}"
            },
            "url": { "raw": "{{base_url}}/products/{{product_id}}", "host": ["{{base_url}}"], "path": ["products", "{{product_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Designers",
      "item": [
        {
          "name": "List Designers",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": {
              "raw": "{{base_url}}/designers?limit=20",
              "host": ["{{base_url}}"],
              "path": ["designers"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Get Designer by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/designers/{{designer_id}}", "host": ["{{base_url}}"], "path": ["designers", "{{designer_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Follows",
      "item": [
        {
          "name": "Follow Designer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designer_id\": \"{{designer_id}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/follows", "host": ["{{base_url}}"], "path": ["follows"] }
          }
        },
        {
          "name": "Unfollow Designer",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/follows/{{designer_id}}", "host": ["{{base_url}}"], "path": ["follows", "{{designer_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/cart", "host": ["{{base_url}}"], "path": ["cart"] }
          }
        },
        {
          "name": "Add to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{product_id}}\",\n  \"quantity\": 1,\n  \"selected_size\": \"M\"\n}"
            },
            "url": { "raw": "{{base_url}}/cart", "host": ["{{base_url}}"], "path": ["cart"] }
          }
        },
        {
          "name": "Remove from Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/cart/{{cart_item_id}}", "host": ["{{base_url}}"], "path": ["cart", "{{cart_item_id}}"] }
          }
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cart_item_ids\": [\"{{cart_item_id}}\"],\n  \"shipping_address\": {\n    \"street\": \"123 Fashion Ave\",\n    \"city\": \"New York\",\n    \"state\": \"NY\",\n    \"zip\": \"10001\",\n    \"country\": \"US\"\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/checkout", "host": ["{{base_url}}"], "path": ["checkout"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "apikey", "value": "{{anon_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\"\n}"
            },
            "url": { "raw": "{{base_url}}/orders/{{order_id}}/status", "host": ["{{base_url}}"], "path": ["orders", "{{order_id}}", "status"] }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Designer Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "apikey", "value": "{{anon_key}}" }],
            "url": { "raw": "{{base_url}}/analytics", "host": ["{{base_url}}"], "path": ["analytics"] }
          }
        }
      ]
    }
  ]
}
