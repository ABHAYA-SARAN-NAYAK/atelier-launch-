# ============================================================================
# ATELIER LAUNCH — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ============================================================================

# ── Supabase ──
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Edge Function Secrets (set via Supabase Dashboard > Settings > Edge Functions) ──
# These are SERVER-ONLY secrets — do NOT prefix with VITE_ or they will leak to the browser!
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# ── Email (Resend — free: 100 emails/day, 3,000/month) ──
# RESEND_API_KEY=re_...
# FROM_EMAIL=Atelier Launch <noreply@yourdomain.com>

# ── App ──
# SITE_URL=https://atelierlaunch.com
VITE_SITE_URL=http://localhost:5173
